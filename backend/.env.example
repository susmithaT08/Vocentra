# Vocentra Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string (REQUIRED in production)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# JWT secret for authentication tokens
JWT_SECRET=your_jwt_secret_here

# Google Gemini API key for AI features
GEMINI_API_KEY=your_gemini_api_key_here

# Email configuration (for OTP verification)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Server port (Render sets this automatically)
PORT=5000

# Node environment
NODE_ENV=production

# CORS origin (comma-separated for multiple origins)
# Set this to your Vercel frontend URL
CORS_ORIGIN=https://your-app.vercel.app
